# ============================================
# VPN Management System - Environment Config
# ============================================

# ==================== General ====================
PROJECT_NAME="VPN Management System"
ENVIRONMENT=production  # development, staging, production
DEBUG=false
SECRET_KEY=your-super-secret-key-change-this-in-production

# ==================== Database ====================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=vpn_management
POSTGRES_USER=vpn_admin
POSTGRES_PASSWORD=change-this-secure-password

# Database URL (auto-constructed)
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ==================== Redis ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# ==================== Backend ====================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=4
BACKEND_RELOAD=false  # true em development

# CORS Origins (separados por vírgula)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://vpn.example.com

# ==================== JWT/Auth ====================
# JWT Secret (gerar com: openssl rand -hex 32)
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# MFA/2FA
MFA_ISSUER_NAME="VPN Management"
MFA_DIGITS=6
MFA_PERIOD=30

# Password Requirements
MIN_PASSWORD_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true

# ==================== OpenVPN ====================
OPENVPN_HOST=vpn.example.com  # Seu domínio público
OPENVPN_PORT=1194
OPENVPN_PROTOCOL=udp  # udp ou tcp
OPENVPN_NETWORK=10.8.0.0
OPENVPN_NETMASK=255.255.255.0
OPENVPN_DNS_1=8.8.8.8
OPENVPN_DNS_2=1.1.1.1

# Caminhos OpenVPN (dentro do container)
OPENVPN_CONFIG_DIR=/etc/openvpn
OPENVPN_PKI_DIR=/etc/openvpn/pki
OPENVPN_CCD_DIR=/etc/openvpn/ccd

# EasyRSA
EASYRSA_KEY_SIZE=2048
EASYRSA_CA_EXPIRE=7500  # dias
EASYRSA_CERT_EXPIRE=3650  # dias
EASYRSA_REQ_COUNTRY=BR
EASYRSA_REQ_PROVINCE=RS
EASYRSA_REQ_CITY="Porto Alegre"
EASYRSA_REQ_ORG="MyOrg"
EASYRSA_REQ_EMAIL=admin@example.com
EASYRSA_REQ_OU="Server Managerment"

# ==================== Network ====================
# Interface pública (conectada à internet)
PUBLIC_INTERFACE=ens5
PUBLIC_IP=auto  # ou IP fixo

# NAT de gateway: sub-rede privada que usa este host como NAT gateway.
# Ex.: 10.48.0.0/16. Vazio = desabilitado. O nat-agent instala o masquerade
# (saddr <rede> -> PUBLIC_INTERFACE) + regras de FORWARD, e reaplica no boot.
NAT_GATEWAY_NETWORK=

# ==================== IPsec (StrongSwan) ====================
# IPsec Agent runs on host to execute StrongSwan commands
# Install with: cd docker/ipsec-agent && sudo ./install.sh
IPSEC_AGENT_URL=http://172.17.0.1:8101  # Docker host IP
IPSEC_AGENT_TOKEN=changeme-ipsec-token  # Set during agent install

# ==================== Firewall ====================
FIREWALL_ENGINE=nftables  # nftables ou iptables
FIREWALL_DEFAULT_POLICY=drop  # drop ou accept
ENABLE_IP_FORWARDING=true
ENABLE_NAT=true

# ==================== Email (opcional) ====================
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your-email-password
SMTP_TLS=true
SMTP_FROM=noreply@example.com

# ==================== Monitoring ====================
ENABLE_METRICS=true
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ==================== Logging ====================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # json ou text
LOG_FILE=/var/log/vpn-management/app.log

# Audit logs retention (days)
AUDIT_LOG_RETENTION_DAYS=365

# ==================== Backup ====================
BACKUP_ENABLED=true
BACKUP_DIR=/var/backups/vpn-management
BACKUP_SCHEDULE="0 2 * * *"  # Cron: 2AM diariamente
BACKUP_RETENTION_DAYS=30

# ==================== Rate Limiting ====================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ==================== Frontend ====================
VITE_API_URL=http://localhost:8000
VITE_APP_NAME="VPN Management"
VITE_ENABLE_ANALYTICS=false

# ==================== Admin Inicial ====================
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=ChangeThisPassword123!
INITIAL_ADMIN_REQUIRE_MFA=true

# ==================== Features Flags ====================
FEATURE_ALLOW_USER_REGISTRATION=false
FEATURE_ENABLE_2FA=true
FEATURE_ENABLE_API_KEYS=true
FEATURE_ENABLE_LDAP=false
FEATURE_ENABLE_RADIUS=false

# ==================== LDAP (se habilitado) ====================
LDAP_SERVER=ldap://ldap.example.com
LDAP_PORT=389
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=ldap-password
LDAP_SEARCH_BASE=ou=users,dc=example,dc=com

# ==================== Performance ====================
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Cache TTL (seconds)
CACHE_TTL_SHORT=300  # 5 minutos
CACHE_TTL_MEDIUM=3600  # 1 hora
CACHE_TTL_LONG=86400  # 24 horas

# ==================== Quotas & Limits ====================
MAX_USERS=1000
MAX_SERVICE_ACCOUNTS=100
MAX_CONCURRENT_CONNECTIONS_PER_USER=5
MAX_FIREWALL_RULES_PER_USER=50
MAX_BANDWIDTH_MBPS_DEFAULT=100

# ==================== Development ====================
DEV_AUTO_RELOAD=true
DEV_DEBUG_SQL=false
DEV_SEED_DATABASE=false
