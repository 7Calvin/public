#!/bin/bash
#
# vpnctl - VPN Management System Control Script
#
# Usage: vpnctl <command> [options]
#

set -e

INSTALL_DIR="/opt/vpn-management"
COMPOSE_FILE="${INSTALL_DIR}/docker-compose.yml"
ENV_FILE="${INSTALL_DIR}/config/.env"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

print_usage() {
    echo "VPN Management System Control"
    echo
    echo "Usage: vpnctl <command> [options]"
    echo
    echo "Commands:"
    echo "  start         Start all services"
    echo "  stop          Stop all services"
    echo "  restart       Restart all services"
    echo "  status        Show service status"
    echo "  logs          View logs (use -f to follow)"
    echo "  update        Update to latest version"
    echo "  backup        Create backup"
    echo "  restore       Restore from backup"
    echo "  shell         Open shell in container"
    echo "  reset-admin   Reset admin password"
    echo "  renew-certs   Renew SSL certificates"
    echo "  vpn-status    Show VPN connections"
    echo "  help          Show this help"
    echo
    echo "Examples:"
    echo "  vpnctl start"
    echo "  vpnctl logs -f backend"
    echo "  vpnctl shell backend"
    echo "  vpnctl backup"
    echo
}

check_installed() {
    if [ ! -f "$COMPOSE_FILE" ]; then
        echo -e "${RED}Error: VPN Management System is not installed${NC}"
        echo "Run install.sh first"
        exit 1
    fi
}

cmd_start() {
    echo -e "${BLUE}Starting services...${NC}"
    cd "$INSTALL_DIR"
    docker compose --env-file "$ENV_FILE" up -d
    echo -e "${GREEN}Services started${NC}"
}

cmd_stop() {
    echo -e "${BLUE}Stopping services...${NC}"
    cd "$INSTALL_DIR"
    docker compose --env-file "$ENV_FILE" down
    echo -e "${GREEN}Services stopped${NC}"
}

cmd_restart() {
    echo -e "${BLUE}Restarting services...${NC}"
    cd "$INSTALL_DIR"
    docker compose --env-file "$ENV_FILE" restart
    echo -e "${GREEN}Services restarted${NC}"
}

cmd_status() {
    cd "$INSTALL_DIR"
    docker compose --env-file "$ENV_FILE" ps
}

cmd_logs() {
    cd "$INSTALL_DIR"
    docker compose --env-file "$ENV_FILE" logs "$@"
}

cmd_update() {
    echo -e "${BLUE}Updating VPN Management System...${NC}"
    cd "$INSTALL_DIR"

    # Backup first
    echo "Creating backup before update..."
    cmd_backup

    # Pull latest images
    echo "Pulling latest images..."
    docker compose --env-file "$ENV_FILE" pull

    # Rebuild and restart
    echo "Rebuilding and restarting..."
    docker compose --env-file "$ENV_FILE" up -d --build

    echo -e "${GREEN}Update complete${NC}"
}

cmd_backup() {
    BACKUP_DIR="${INSTALL_DIR}/backups"
    BACKUP_NAME="backup_$(date +%Y%m%d_%H%M%S)"
    BACKUP_PATH="${BACKUP_DIR}/${BACKUP_NAME}"

    echo -e "${BLUE}Creating backup: ${BACKUP_NAME}${NC}"
    mkdir -p "$BACKUP_PATH"

    # Backup database
    echo "Backing up database..."
    cd "$INSTALL_DIR"
    docker compose --env-file "$ENV_FILE" exec -T postgres \
        pg_dump -U vpn_admin vpn_management > "${BACKUP_PATH}/database.sql"

    # Backup OpenVPN PKI
    echo "Backing up OpenVPN certificates..."
    cp -r "${INSTALL_DIR}/data/openvpn/pki" "${BACKUP_PATH}/" 2>/dev/null || true

    # Backup config
    echo "Backing up configuration..."
    cp "${ENV_FILE}" "${BACKUP_PATH}/"

    # Compress
    echo "Compressing..."
    cd "$BACKUP_DIR"
    tar -czf "${BACKUP_NAME}.tar.gz" "${BACKUP_NAME}"
    rm -rf "${BACKUP_PATH}"

    echo -e "${GREEN}Backup created: ${BACKUP_DIR}/${BACKUP_NAME}.tar.gz${NC}"
}

cmd_restore() {
    if [ -z "$1" ]; then
        echo "Usage: vpnctl restore <backup_file>"
        echo
        echo "Available backups:"
        ls -la "${INSTALL_DIR}/backups/"*.tar.gz 2>/dev/null || echo "  No backups found"
        exit 1
    fi

    BACKUP_FILE="$1"
    if [ ! -f "$BACKUP_FILE" ]; then
        BACKUP_FILE="${INSTALL_DIR}/backups/$1"
    fi

    if [ ! -f "$BACKUP_FILE" ]; then
        echo -e "${RED}Backup file not found: $1${NC}"
        exit 1
    fi

    echo -e "${YELLOW}WARNING: This will overwrite current data!${NC}"
    read -p "Are you sure? (yes/no): " confirm
    if [ "$confirm" != "yes" ]; then
        echo "Cancelled"
        exit 0
    fi

    TEMP_DIR=$(mktemp -d)
    echo -e "${BLUE}Restoring from ${BACKUP_FILE}...${NC}"

    # Extract
    tar -xzf "$BACKUP_FILE" -C "$TEMP_DIR"
    BACKUP_DIR=$(ls "$TEMP_DIR")

    # Stop services
    cmd_stop

    # Restore database
    if [ -f "${TEMP_DIR}/${BACKUP_DIR}/database.sql" ]; then
        echo "Restoring database..."
        cmd_start postgres
        sleep 5
        cd "$INSTALL_DIR"
        docker compose --env-file "$ENV_FILE" exec -T postgres \
            psql -U vpn_admin vpn_management < "${TEMP_DIR}/${BACKUP_DIR}/database.sql"
    fi

    # Restore PKI
    if [ -d "${TEMP_DIR}/${BACKUP_DIR}/pki" ]; then
        echo "Restoring OpenVPN certificates..."
        rm -rf "${INSTALL_DIR}/data/openvpn/pki"
        cp -r "${TEMP_DIR}/${BACKUP_DIR}/pki" "${INSTALL_DIR}/data/openvpn/"
    fi

    # Cleanup
    rm -rf "$TEMP_DIR"

    # Restart
    cmd_start

    echo -e "${GREEN}Restore complete${NC}"
}

cmd_shell() {
    CONTAINER=${1:-backend}
    cd "$INSTALL_DIR"
    docker compose --env-file "$ENV_FILE" exec "$CONTAINER" /bin/sh
}

cmd_reset_admin() {
    echo -e "${BLUE}Resetting admin password...${NC}"

    NEW_PASSWORD=$(openssl rand -base64 16 | tr -dc 'a-zA-Z0-9' | head -c 16)

    cd "$INSTALL_DIR"
    docker compose --env-file "$ENV_FILE" exec backend \
        python -c "
from app.db.session import AsyncSessionLocal
from app.models.user import User
from app.core.security import hash_password
import asyncio

async def reset():
    async with AsyncSessionLocal() as db:
        from sqlalchemy import select
        result = await db.execute(select(User).where(User.username == 'admin'))
        admin = result.scalar_one_or_none()
        if admin:
            admin.password_hash = hash_password('${NEW_PASSWORD}')
            await db.commit()
            print('Password reset successfully')
        else:
            print('Admin user not found')

asyncio.run(reset())
"

    echo
    echo -e "${GREEN}Admin password has been reset${NC}"
    echo -e "New password: ${YELLOW}${NEW_PASSWORD}${NC}"
    echo
    echo -e "${RED}Please save this password and change it after login!${NC}"
}

cmd_vpn_status() {
    echo -e "${BLUE}VPN Connection Status${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

    cd "$INSTALL_DIR"
    docker compose --env-file "$ENV_FILE" exec openvpn cat /etc/openvpn/logs/status.log 2>/dev/null || \
        echo "No active connections or status file not available"
}

cmd_renew_certs() {
    echo -e "${BLUE}Renewing SSL certificates...${NC}"

    # Check if using Let's Encrypt
    if [ -f "${INSTALL_DIR}/certs/.letsencrypt" ]; then
        cd "$INSTALL_DIR"
        docker compose --env-file "$ENV_FILE" exec nginx certbot renew
        docker compose --env-file "$ENV_FILE" exec nginx nginx -s reload
        echo -e "${GREEN}Certificates renewed${NC}"
    else
        echo "Not using Let's Encrypt. Generate new self-signed certificate manually."
    fi
}

# Main
case "${1:-help}" in
    start)
        check_installed
        cmd_start
        ;;
    stop)
        check_installed
        cmd_stop
        ;;
    restart)
        check_installed
        cmd_restart
        ;;
    status)
        check_installed
        cmd_status
        ;;
    logs)
        check_installed
        shift
        cmd_logs "$@"
        ;;
    update)
        check_installed
        cmd_update
        ;;
    backup)
        check_installed
        cmd_backup
        ;;
    restore)
        check_installed
        shift
        cmd_restore "$@"
        ;;
    shell)
        check_installed
        shift
        cmd_shell "$@"
        ;;
    reset-admin)
        check_installed
        cmd_reset_admin
        ;;
    vpn-status)
        check_installed
        cmd_vpn_status
        ;;
    renew-certs)
        check_installed
        cmd_renew_certs
        ;;
    help|--help|-h)
        print_usage
        ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        print_usage
        exit 1
        ;;
esac
